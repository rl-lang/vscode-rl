{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "rl",
  "scopeName": "source.rl",
  "fileTypes": ["rl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rl",
          "match": "//.*$"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.rl",
          "match": "(!#)\\s*(\\[)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.bang.rl" },
            "2": { "name": "punctuation.bracket.rl" },
            "3": { "name": "entity.name.tag.rl" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rl",
          "match": "\\b(if|else|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.rl",
          "match": "\\b(fn|dec|CONST|arr|const)\\b"
        },
        {
          "name": "keyword.import.rl",
          "match": "\\b(get|from)\\b"
        },
        {
          "name": "keyword.operator.logical.rl",
          "match": "\\b(and|or)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.rl",
          "match": "\\b(int|float|bool|string|char|arr)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "string.quoted.double.rl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.rl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.rl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.rl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "constant.numeric.float.rl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.rl",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.language.boolean.rl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.rl",
          "match": "\\bnull\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.rl",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.rl" },
            "2": { "name": "entity.name.function.rl" }
          }
        },
        {
          "name": "entity.name.function.call.rl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.rl" }
          }
        },
        {
          "name": "entity.name.function.method.rl",
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.method.rl" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rl",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.rl",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.rl",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.arrow.rl",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.rl",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.path.rl",
          "match": "::"
        },
        {
          "name": "keyword.operator.bang.rl",
          "match": "!#|!"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.rl",
          "match": "[()\\[\\]{}]"
        },
        {
          "name": "punctuation.separator.rl",
          "match": ","
        },
        {
          "name": "punctuation.delimiter.rl",
          "match": "\\."
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.rl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
